# Pulp configuration — copy this file to `.env.local` and fill in real values.
#   cp .env.example .env.local
# `.env.local` is git-ignored; this template is the only env file that's committed,
# so never put real secrets here. See README "Configuration" for the full table.

# Required. Used ONLY by app/lib/digest.ts to call the Claude API (the one LLM boundary).
# Get a key at https://console.anthropic.com/ — keep it out of git and never print it.
ANTHROPIC_API_KEY=

# Optional. One RSS feed URL, or several comma-separated. Defaults to merged NPR topic
# feeds when unset. This is the whole point — make it yours.
# Example: RSS_FEED_URL=https://feeds.npr.org/1001/rss.xml,https://feeds.npr.org/1004/rss.xml
RSS_FEED_URL=
